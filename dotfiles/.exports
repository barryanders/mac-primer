#!/usr/bin/env bash

# Make Sublime Text the default editor
export EDITOR="subl -w";
export VISUAL="vi";

# Increase Bash history size. Allow 32⁴ entries; the default is 500
export HISTSIZE='1048576';
# Disable Bash history
# export HISTSIZE='0';
export HISTFILESIZE="${HISTSIZE}";
# Omit duplicates and commands that begin with a space from history.
export HISTCONTROL='ignoreboth';

# Specify your defaults in this environment variable
export HOMEBREW_CASK_OPTS="--appdir=/Applications" # --caskroom=/usr/local/Caskroom"

# Prefer US English and use UTF-8
export LANG='en_US.UTF-8';
export LC_ALL='en_US.UTF-8';

# Avoid issues with `gpg` as installed via Homebrew
# https://stackoverflow.com/a/42265848/96656
export GPG_TTY=$(tty);

# Hide the "default interactive shell is now zsh" warning on macOS
export BASH_SILENCE_DEPRECATION_WARNING=1;

# Metroid Prime Sound Effects (0 = off, 1 = on)
export DOTFILES_SOUND=1;

# Metroid Prime / Ghostty terminal colors
export CLICOLOR=1;
export LSCOLORS="GxFxCxDxBxegedabagaced";

# GNU/BSD tools that respect LS_COLORS
export LS_COLORS='di=1;36:ln=1;34:so=1;35:pi=33:ex=1;32:bd=34;46:cd=34;43:su=30;41:sg=30;46:tw=30;42:ow=30;43:*.sh=1;32:*.bash=1;32:*.zsh=1;32:*.py=1;36:*.js=1;33:*.ts=1;33:*.json=38;5;214:*.toml=38;5;214:*.yml=38;5;214:*.yaml=38;5;214:*.md=38;5;111:*.txt=38;5;159:*.log=38;5;245:*.png=38;5;141:*.jpg=38;5;141:*.jpeg=38;5;141:*.gif=38;5;141:*.pdf=38;5;203:*.zip=38;5;208:*.tar=38;5;208:*.gz=38;5;208';
